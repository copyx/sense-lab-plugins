{
  "name": "linkedin-saved-posts-analyzer",
  "version": "2.0.0",
  "description": "Extract and analyze your LinkedIn saved posts using Agent SDK",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "extract": "node src/extractor.js",
    "analyze": "node src/agent-analyzer.js",
    "analyze:legacy": "node src/analyzer.js",
    "analyze:api": "node src/agent-analyzer.js --api-key",
    "report": "node src/reporter.js",
    "pipeline": "npm run extract && npm run analyze && npm run report",
    "setup": "node src/setup.js",
    "capture-cookie": "node src/capture-cookie.js",
    "postinstall": "playwright install chromium --with-deps",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": ["linkedin", "analysis", "playwright", "ai", "agent-sdk", "claude"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.40.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
