# LinkedIn Authentication
# Get this cookie from your browser:
# 1. Login to LinkedIn
# 2. Open DevTools (F12) → Application → Cookies → https://www.linkedin.com
# 3. Copy the value of 'li_at' cookie
LINKEDIN_LI_AT_COOKIE=your_li_at_cookie_here

# Claude API (OPTIONAL - only for standalone API mode)
# The analyzer uses Claude Code's Agent SDK by default (no API key needed)
# Only set this if you want to use direct API mode with --api-key flag
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Proxy (if needed)
# PROXY_URL=http://proxy-server:port

# Report Configuration
REPORT_FREQUENCY=weekly
# Options: daily, weekly, monthly
